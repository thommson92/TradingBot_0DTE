# Kopiere diese Datei nach .env und trage deinen echten Key ein.
# .env ist via .gitignore ausgeschlossen und wird NIEMALS committet.

# ThetaData API-Key. Wird von der offiziellen thetadata-Python-Library
# direkt genutzt, um sich mit der ThetaData-Cloud zu verbinden
# (kein lokales Theta Terminal noetig).
THETADATA_API_KEY=dein_key_hier
